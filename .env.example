# Copie ce fichier en .env.local et remplis les valeurs
# Trouve ces valeurs dans ton projet Supabase : Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Clés VAPID pour les notifications push
# Génère avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# Secret optionnel pour sécuriser le endpoint cron (mis dans Vercel env vars)
CRON_SECRET=...
